// math/operations.rou
// Provides basic mathematical operations

import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib



function add(a, b) {
    return a + b
}

function sub(a, b) {
    return a - b
}

function mul(a, b) {
    return a * b
}

function div(a, b) {
    if (b == 0) {
        throw "Division by zero"
    }
    return a / b
}
