// math/operations.rou
// Provides basic mathematical operations

import stdlib io as io
import stdlib core as core
import stdlib array as arr
import stdlib string as str



function add(a, b) {
    return a + b
}

function sub(a, b) {
    return a - b
}

function mul(a, b) {
    return a * b
}

function div(a, b) {
    if (b == 0) {
        throw "Division by zero"
    }
    return a / b
}
