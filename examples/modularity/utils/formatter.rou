// utils/formatter.rou
// Formatting utility functions

import stdlib io as io
import stdlib core as core
import stdlib array as arr
import stdlib string as str



import "../config.rou" as config

function formatResult(operation, a, b, result) {
    prefix = ""
    cfg = config.getConfig()
    
    if (cfg.debug) {
        prefix = "[DEBUG] "
    }
    
    return prefix + operation + " of " + core.toString(a) + " and " + core.toString(b) + " is: " + core.toString(result)
}
