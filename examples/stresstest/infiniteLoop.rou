import stdlib io as io
import stdlib core as core
import stdlib array as arr
import stdlib string as str


function run() {
    io.print("Testing infinite loop (Target: Watchdog Timeout Guard, no freeze)...")
    while (true) {
        // Do nothing. This loop will run forever unless the runtimeGuard kills it.
    }
}

try {
    run()
} catch (err) {
    io.print("Intercepted: " + core.toString(err))
}
