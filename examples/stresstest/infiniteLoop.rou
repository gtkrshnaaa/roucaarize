import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib


function run() {
    ioLib.print("Testing infinite loop (Target: Watchdog Timeout Guard, no freeze)...")
    while (true) {
        // Do nothing. This loop will run forever unless the runtimeGuard kills it.
    }
}

try {
    run()
} catch (err) {
    ioLib.print("Intercepted: " + coreLib.toString(err))
}
