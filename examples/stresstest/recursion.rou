import stdlib io as io
import stdlib core as core
import stdlib array as arr
import stdlib string as str


function deepCall(n) {
    return deepCall(n + 1)
}

function run() {
    io.print("Testing infinite recursion (Target: Stack Overflow Guard, no segfault)...")
    deepCall(1)
}

try {
    run()
} catch (err) {
    io.print("Intercepted: " + core.toString(err))
}
