// SQL Parser Mock - String Slicer evaluating linear string into AST objects

import stdlib io as io
import stdlib array as arr
import stdlib string as str



struct ASTQuery { type, columns, table, condition }

function extractSubstring(targetStr, from, lengthConstraint) {
    res = ""
    i = from
    safeLen = from + lengthConstraint
    if (safeLen > str.length(targetStr)) { safeLen = str.length(targetStr) }
    
    while (i < safeLen) {
        res += targetStr[i]
        i++
    }
    return res
}

function parseSQL(query) {
    // Expected basic format: "SELECT a FROM b WHERE c"
    // Since we don't have .indexOf(), we scan manually until space
    ast = ASTQuery("UNKNOWN", [], "", "")
    
    i = 0
    word = ""
    words = []
    
    while (i < str.length(query)) {
        c = query[i]
        if (c == " ") {
            if (word != "") { arr.push(words, word); word = "" }
        } else {
            word += c
        }
        i++
    }
    if (word != "") { arr.push(words, word) } // push last
    
    // [SELECT, id, FROM, users, WHERE, age=12]
    if (words[0] == "SELECT") {
        ast.type = "QUERY"
        arr.push(ast.columns, words[1]) // assume single column for simplicity
        if (words[2] == "FROM") {
            ast.table = words[3]
            if (words[4] == "WHERE") {
                ast.condition = words[5]
            }
        }
    }
    
    return ast
}

function testSQLParser() {
    io.print("--- Testing SQL String AST Parser ---")
    
    sql = "SELECT uuid FROM players WHERE active=1"
    
    res = parseSQL(sql)
    
    io.print("Parsed Table: " + toString(res.table))
    io.print("Parsed Column: " + toString(res.columns[0]))
    io.print("Parsed Condition: " + toString(res.condition))
    
    valid = (res.table == "players" and res.columns[0] == "uuid" and res.condition == "active=1")
    if (!valid) { io.print("FATAL: SQL parser string logic decoupled!") }
}

function main() {
    testSQLParser()
}

main()
