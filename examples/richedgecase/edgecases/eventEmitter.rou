// Event Emitter - Testing Structs holding functions (Methods) and Array manipulation

import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib



struct Emitter {
    listeners
}

function addListener(emitter, eventName, callback) {
    if (emitter.listeners[eventName] == null) {
        emitter.listeners[eventName] = []
    }
    arrLib.push(emitter.listeners[eventName], callback)
}

function triggerEvent(emitter, eventName, payload) {
    list = emitter.listeners[eventName]
    if (list != null) {
        i = 0
        while (i < coreLib.len(list)) {
            cb = list[i]
            cb(payload)
            i++
        }
    }
}

function testEventEmitter() {
    ioLib.print("--- Testing Event Emitter ---")
    system = Emitter({}) // Empty map
    
    globalState = 0
    
    function onData(payload) {
        globalState += payload
    }
    
    function onEnd(payload) {
        globalState *= payload
    }
    
    addListener(system, "data", onData)
    addListener(system, "data", onData) // attached twice
    addListener(system, "end", onEnd)
    
    triggerEvent(system, "data", 5) // +10
    triggerEvent(system, "end", 3)  // *3 -> 30
    
    ioLib.print("Final State: " + coreLib.toString(globalState))
    if (globalState != 30) { ioLib.print("FATAL: Event emitter flow failed") }
}

function main() {
    testEventEmitter()
}

main()
