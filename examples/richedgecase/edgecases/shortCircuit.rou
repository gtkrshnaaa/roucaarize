// Short-circuit Booleans - Roucaarize

import stdlib io as io
import stdlib array as arr
import stdlib string as str



function trapFlag() {
    io.print("FATAL: Short circuit failed, trap executed!")
    return true
}

function testShortCircuit() {
    scBool = false
    result = scBool and trapFlag()
    if (result) { io.print("FATAL: Short-circuit evaluations failed!") }
    io.print("Short circuit guarded successfully.")
}

function main() {
    testShortCircuit()
}

main()
