// Regex Finite Automaton State Machine - Testing logical branching string evaluation without native Regex

import stdlib io as io
import stdlib core as core
import stdlib array as arr
import stdlib string as str



struct NFAState { accept, transitionChar, nextState }

// Matches simple generic literal pattern string format: "a-z" loop
function simulateNFA(stateMachineHead, testStr) {
    curr = stateMachineHead
    
    i = 0
    while (i < core.len(testStr)) {
        c = testStr[i]
        if (c == null) { break }
        
        // Transitions map checks
        nextPointer = curr.transitionChar[c]
        if (nextPointer == null) {
            // Check wildcards
            if (curr.transitionChar["*"] != null) {
                nextPointer = curr.transitionChar["*"]
            } else {
                return false
            }
        }
        
        curr = nextPointer
        i++
    }
    
    return curr.accept
}

function testNFALogic() {
    io.print("--- Testing NFA Regex Automaton Logic ---")
    
    // Build a state machine for regex: `^ab*c$`
    // S0 -'a'-> S1
    // S1 -'b'-> S1 (loop)
    // S1 -'c'-> S2 (accept)
    
    s2 = NFAState(true, {}, null)
    s1 = NFAState(false, {"b": null, "c": s2}, null)
    s1.transitionChar["b"] = s1 // loop reference
    s0 = NFAState(false, {"a": s1}, null)
    
    valid1 = simulateNFA(s0, "abc")
    valid2 = simulateNFA(s0, "abbbbbc")
    invalid1 = simulateNFA(s0, "abbbbcX")
    invalid2 = simulateNFA(s0, "Xbc")
    
    io.print("NFA valid1: " + core.toString(valid1))
    io.print("NFA valid2: " + core.toString(valid2))
    if (!valid1 or !valid2) { io.print("FATAL: NFA state rejected valid linear combinations") }
    if (invalid1 or invalid2) { io.print("FATAL: NFA state breached regex containment logic") }
}

function main() {
    testNFALogic()
}

main()
