// Closure Memoization - Testing high-level scoping encapsulation

import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib



function createMemoizedFibonacci() {
    cache = {0: 0, 1: 1}
    
    function fib(n) {
        val = cache[n]
        if (val != null) {
            return val
        }
        
        // Compute and store
        res = fib(n - 1) + fib(n - 2)
        cache[n] = res
        return res
    }
    
    return fib
}

function testMemoizedFib() {
    ioLib.print("--- Testing Memoized Closure ---")
    fastFib = createMemoizedFibonacci()
    
    res = fastFib(40) // Will instantly return if memoized correctly (otherwise takes minutes)
    ioLib.print("Fib(40) = " + coreLib.toString(res))
    
    if (res != 102334155) { ioLib.print("FATAL: Memoized fib failed math") }
}

function main() {
    testMemoizedFib()
}

main()
