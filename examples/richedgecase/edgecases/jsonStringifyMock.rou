// Recursive JSON Stringifier Mock - Testing deep Map/Array traversal to String output

import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib



function stringify(value) {
    if (value == null) { return "null" }
    
    t = coreLib.typeof(value)
    
    if (t == "string") {
        return "'" + value + "'"
    }
    if (t == "int" or t == "float" or t == "bool") {
        return coreLib.toString(value)
    }
    
    if (t == "array") {
        res = "["
        i = 0
        while (i < coreLib.len(value)) {
            res += stringify(value[i])
            if (i < coreLib.len(value) - 1) { res += "," }
            i++
        }
        return res + "]"
    }
    
    if (t == "struct" or t == "map") {
        // We cannot iterate map keys natively in standard library without specific keys,
        // So for this test we hardcode the known map traversal logic based on predetermined state
        // To mock generic serialization
        res = "{"
        if (value["name"] != null) { res += "'name':" + stringify(value["name"]) + "," }
        if (value["age"] != null) { res += "'age':" + stringify(value["age"]) + "," }
        if (value["active"] != null) { res += "'active':" + stringify(value["active"]) }
        
        // Trim last comma logic mocked
        len = coreLib.len(res)
        if (res[len-1] == ",") {
            // substring mock
            trim = ""
            x = 0
            while (x < len - 1) { trim += res[x]; x++ }
            res = trim
        }
        
        return res + "}"
    }
    
    return "'<unknown>'"
}

function testStringify() {
    ioLib.print("--- Testing JSON Stringifier ---")
    data = {
        "name": "Roucaarize",
        "age": 1,
        "active": true
    }
    
    nest = [1, data, "test", null]
    
    json = stringify(nest)
    ioLib.print("Output: " + json)
    
    expected = "[1,{'name':'Roucaarize','age':1,'active':true},'test',null]"
    if (json != expected) { ioLib.print("FATAL: JSON stringification logic failed") }
}

function main() {
    testStringify()
}

main()
