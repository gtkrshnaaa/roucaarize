// Priority Queue (Min Heap) - Testing array index tree manipulations

import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib



struct MinHeap { array }

function getParent(i) { return (i - 1) / 2 }
function getLeft(i) { return (2 * i) + 1 }
function getRight(i) { return (2 * i) + 2 }

function swap(heap, i, j) {
    temp = heap.array[i]
    heap.array[i] = heap.array[j]
    heap.array[j] = temp
}

function insertHeap(heap, value) {
    arrLib.push(heap.array, value)
    
    // Heapify up
    curr = coreLib.len(heap.array) - 1
    while (curr > 0 and heap.array[curr] < heap.array[getParent(curr)]) {
        swap(heap, curr, getParent(curr))
        curr = getParent(curr)
    }
}

function extractMin(heap) {
    if (coreLib.len(heap.array) == 0) { return null }
    if (coreLib.len(heap.array) == 1) { return arrLib.pop(heap.array) }
    
    minVal = heap.array[0]
    
    // Move last leaf to root
    heap.array[0] = arrLib.pop(heap.array)
    
    // Heapify down
    curr = 0
    keepGoing = true
    while (keepGoing) {
        l = getLeft(curr)
        r = getRight(curr)
        smallest = curr
        
        if (l < coreLib.len(heap.array)) {
            if (heap.array[l] < heap.array[smallest]) {
                smallest = l
            }
        }
        if (r < coreLib.len(heap.array)) {
            if (heap.array[r] < heap.array[smallest]) {
                smallest = r
            }
        }
        
        if (smallest != curr) {
            swap(heap, curr, smallest)
            curr = smallest
        } else {
            keepGoing = false
        }
    }
    
    return minVal
}

function testMinHeap() {
    ioLib.print("--- Testing Min Heap Data Structure ---")
    h = MinHeap([])
    
    insertHeap(h, 50)
    insertHeap(h, 20)
    insertHeap(h, 80)
    insertHeap(h, 10)
    insertHeap(h, 30)
    insertHeap(h, 5)
    
    output = []
    i = 0
    while (i < 6) {
        arrLib.push(output, extractMin(h))
        i++
    }
    
    ioLib.print("Heap Sorted Extraction:")
    j = 0
    while (j < 6) { ioLib.print(coreLib.toString(output[j])); j++ }
    
    if (output[0] != 5 or output[5] != 80) { ioLib.print("FATAL: Min Heap tree rotation corrupted sorting") }
}

function main() {
    testMinHeap()
}

main()
