// Array Bubble Sort - Roucaarize

import stdlib io as ioLib
import stdlib core as coreLib
import stdlib array as arrLib
import stdlib string as strLib



function bubbleSort(arr) {
    len = coreLib.len(arr)
    i = 0
    while (i < len) {
        j = 0
        while (j < len - i - 1) {
            if (arr[j] > arr[j + 1]) {
                // Swap
                temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    return arr
}

function testSorting() {
    unsorted = [64, 34, 25, 12, 22, 11, 90]
    sorted = bubbleSort(unsorted)
    ioLib.print("Sorted Output: " + coreLib.toString(sorted[0]) + " ... " + coreLib.toString(sorted[6]))
    if (sorted[0] != 11) { ioLib.print("FATAL: bubbleSort() min bound failed!") }
    if (sorted[6] != 90) { ioLib.print("FATAL: bubbleSort() max bound failed!") }
}

function main() {
    testSorting()
}

main()
