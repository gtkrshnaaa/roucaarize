// Basic Algorithms Test - Roucaarize
// Tests classic computer science problems (Fibonacci)

function fibonacci(n) {
    if (n <= 1) {
        return n
    }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

function testFibonacci() {
    result = fibonacci(15)
    print("Fibonacci(15) = " + toString(result))
    if (result != 610) { print("FATAL: fibonacci() failed!") }
}

function main() {
    testFibonacci()
}

main()
