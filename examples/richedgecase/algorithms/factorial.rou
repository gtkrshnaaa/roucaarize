// Iterative Factorial - Roucaarize

function factorial(n) {
    result = 1
    i = 1
    while (i <= n) {
        result = result * i
        i = i + 1
    }
    return result
}

function testFactorial() {
    result = factorial(10)
    print("Factorial(10) = " + toString(result))
    if (result != 3628800) { print("FATAL: factorial() failed!") }
}

function main() {
    testFactorial()
}

main()
