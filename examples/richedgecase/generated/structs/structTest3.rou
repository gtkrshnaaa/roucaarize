// Generated Struct Test 3

struct Engine3 {
    id, power, status
}

function testStruct3() {
    e = Engine3(3, 300, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 3) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 350) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct3()
}

main()
