// Generated Struct Test 16

struct Engine16 {
    id, power, status
}

function testStruct16() {
    e = Engine16(16, 1600, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 16) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 1650) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct16()
}

main()
