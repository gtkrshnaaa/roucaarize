// Generated Struct Test 10

struct Engine10 {
    id, power, status
}

function testStruct10() {
    e = Engine10(10, 1000, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 10) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 1050) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct10()
}

main()
