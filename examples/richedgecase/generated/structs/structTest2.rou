// Generated Struct Test 2

struct Engine2 {
    id, power, status
}

function testStruct2() {
    e = Engine2(2, 200, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 2) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 250) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct2()
}

main()
