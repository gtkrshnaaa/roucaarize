// Generated Struct Test 18

struct Engine18 {
    id, power, status
}

function testStruct18() {
    e = Engine18(18, 1800, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 18) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 1850) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct18()
}

main()
