// Generated Struct Test 1

struct Engine1 {
    id, power, status
}

function testStruct1() {
    e = Engine1(1, 100, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 1) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 150) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct1()
}

main()
