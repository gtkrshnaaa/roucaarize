// Generated Struct Test 25

struct Engine25 {
    id, power, status
}

function testStruct25() {
    e = Engine25(25, 2500, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 25) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 2550) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct25()
}

main()
