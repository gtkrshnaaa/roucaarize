// Generated Struct Test 20

struct Engine20 {
    id, power, status
}

function testStruct20() {
    e = Engine20(20, 2000, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 20) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 2050) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct20()
}

main()
