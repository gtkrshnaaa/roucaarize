// Generated Struct Test 5

struct Engine5 {
    id, power, status
}

function testStruct5() {
    e = Engine5(5, 500, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 5) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 550) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct5()
}

main()
