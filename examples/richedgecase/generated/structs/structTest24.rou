// Generated Struct Test 24

struct Engine24 {
    id, power, status
}

function testStruct24() {
    e = Engine24(24, 2400, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 24) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 2450) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct24()
}

main()
