// Generated Struct Test 23

struct Engine23 {
    id, power, status
}

function testStruct23() {
    e = Engine23(23, 2300, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 23) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 2350) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct23()
}

main()
