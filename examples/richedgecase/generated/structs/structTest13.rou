// Generated Struct Test 13

struct Engine13 {
    id, power, status
}

function testStruct13() {
    e = Engine13(13, 1300, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 13) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 1350) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct13()
}

main()
