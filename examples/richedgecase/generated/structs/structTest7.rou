// Generated Struct Test 7

struct Engine7 {
    id, power, status
}

function testStruct7() {
    e = Engine7(7, 700, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 7) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 750) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct7()
}

main()
