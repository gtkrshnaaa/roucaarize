// Generated Struct Test 9

struct Engine9 {
    id, power, status
}

function testStruct9() {
    e = Engine9(9, 900, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 9) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 950) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct9()
}

main()
