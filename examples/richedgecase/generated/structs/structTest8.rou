// Generated Struct Test 8

struct Engine8 {
    id, power, status
}

function testStruct8() {
    e = Engine8(8, 800, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 8) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 850) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct8()
}

main()
