// Generated Struct Test 17

struct Engine17 {
    id, power, status
}

function testStruct17() {
    e = Engine17(17, 1700, "idle")
    e.status = "running"
    e.power += 50
    
    if (e.id != 17) { print("FATAL: Struct ID mismatch") }
    if (e.status != "running") { print("FATAL: Struct status mutation failed") }
    if (e.power != 1750) { print("FATAL: Struct power mutation failed") }
}

function main() {
    testStruct17()
}

main()
