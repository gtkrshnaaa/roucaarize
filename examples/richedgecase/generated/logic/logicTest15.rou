// Generated Logic Test 15

function testLogic15() {
    counter = 0
    val = 0
    while (counter < 44) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 44) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic15()
}

main()
