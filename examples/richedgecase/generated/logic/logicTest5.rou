// Generated Logic Test 5

function testLogic5() {
    counter = 0
    val = 0
    while (counter < 80) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 80) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic5()
}

main()
