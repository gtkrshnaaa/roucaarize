// Generated Logic Test 19

function testLogic19() {
    counter = 0
    val = 0
    while (counter < 88) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 88) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic19()
}

main()
