// Generated Logic Test 12

function testLogic12() {
    counter = 0
    val = 0
    while (counter < 69) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 69) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic12()
}

main()
