// Generated Logic Test 3

function testLogic3() {
    counter = 0
    val = 0
    while (counter < 93) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 93) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic3()
}

main()
