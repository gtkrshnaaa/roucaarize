// Generated Logic Test 21

function testLogic21() {
    counter = 0
    val = 0
    while (counter < 85) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 85) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic21()
}

main()
