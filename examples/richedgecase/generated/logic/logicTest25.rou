// Generated Logic Test 25

function testLogic25() {
    counter = 0
    val = 0
    while (counter < 96) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 96) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic25()
}

main()
