// Generated Logic Test 18

function testLogic18() {
    counter = 0
    val = 0
    while (counter < 66) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 66) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic18()
}

main()
