// Generated Logic Test 11

function testLogic11() {
    counter = 0
    val = 0
    while (counter < 76) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 76) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic11()
}

main()
