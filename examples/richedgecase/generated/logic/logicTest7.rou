// Generated Logic Test 7

function testLogic7() {
    counter = 0
    val = 0
    while (counter < 17) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 17) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic7()
}

main()
