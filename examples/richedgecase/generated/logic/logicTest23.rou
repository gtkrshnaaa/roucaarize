// Generated Logic Test 23

function testLogic23() {
    counter = 0
    val = 0
    while (counter < 21) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 21) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic23()
}

main()
