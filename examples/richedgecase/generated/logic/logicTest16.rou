// Generated Logic Test 16

function testLogic16() {
    counter = 0
    val = 0
    while (counter < 63) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 63) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic16()
}

main()
