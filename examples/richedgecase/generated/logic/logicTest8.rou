// Generated Logic Test 8

function testLogic8() {
    counter = 0
    val = 0
    while (counter < 71) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 71) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic8()
}

main()
