// Generated Logic Test 17

function testLogic17() {
    counter = 0
    val = 0
    while (counter < 37) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 37) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic17()
}

main()
