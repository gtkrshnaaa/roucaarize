// Generated Logic Test 22

function testLogic22() {
    counter = 0
    val = 0
    while (counter < 40) {
        if (counter % 2 == 0) {
            val += 2
        } else {
            val += 1
        }
        counter++
    }
    
    if (counter != 40) { print("FATAL: loop did not terminate correctly") }
}

function main() {
    testLogic22()
}

main()
