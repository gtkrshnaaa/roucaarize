// Generated Closure Test 25

function createMultiplier25(factor) {
    function multiply(val) {
        return val * factor
    }
    return multiply
}

function testClosure25() {
    mul = createMultiplier25(25)
    result = mul(10)
    if (result != 250) { print("FATAL: Closure multiplication failed") }
}

function main() {
    testClosure25()
}

