// Generated Closure Test 1

function createMultiplier1(factor) {
    function multiply(val) {
        return val * factor
    }
    return multiply
}

function testClosure1() {
    mul = createMultiplier1(1)
    result = mul(10)
    if (result != 10) { print("FATAL: Closure multiplication failed") }
}

function main() {
    testClosure1()
}

main()
