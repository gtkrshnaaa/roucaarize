// Generated Closure Test 4

function createMultiplier4(factor) {
    function multiply(val) {
        return val * factor
    }
    return multiply
}

function testClosure4() {
    mul = createMultiplier4(4)
    result = mul(10)
    if (result != 40) { print("FATAL: Closure multiplication failed") }
}

function main() {
    testClosure4()
}

main()
