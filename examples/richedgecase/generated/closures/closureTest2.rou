// Generated Closure Test 2

function createMultiplier2(factor) {
    function multiply(val) {
        return val * factor
    }
    return multiply
}

function testClosure2() {
    mul = createMultiplier2(2)
    result = mul(10)
    if (result != 20) { print("FATAL: Closure multiplication failed") }
}

function main() {
    testClosure2()
}

main()
