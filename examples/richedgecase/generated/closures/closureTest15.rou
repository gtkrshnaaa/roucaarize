// Generated Closure Test 15

function createMultiplier15(factor) {
    function multiply(val) {
        return val * factor
    }
    return multiply
}

function testClosure15() {
    mul = createMultiplier15(15)
    result = mul(10)
    if (result != 150) { print("FATAL: Closure multiplication failed") }
}

function main() {
    testClosure15()
}

main()
