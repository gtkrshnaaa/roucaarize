// Generated Array Test 19

function testArray19() {
    arr = []
    idx = 0
    while (idx < 35) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 35) { print("FATAL: array length mismatch") }
    if (arr[35-1] != (35-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray19()
}

main()
