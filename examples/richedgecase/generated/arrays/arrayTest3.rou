// Generated Array Test 3

function testArray3() {
    arr = []
    idx = 0
    while (idx < 24) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 24) { print("FATAL: array length mismatch") }
    if (arr[24-1] != (24-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray3()
}

main()
