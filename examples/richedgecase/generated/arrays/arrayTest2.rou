// Generated Array Test 2

function testArray2() {
    arr = []
    idx = 0
    while (idx < 18) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 18) { print("FATAL: array length mismatch") }
    if (arr[18-1] != (18-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray2()
}

main()
