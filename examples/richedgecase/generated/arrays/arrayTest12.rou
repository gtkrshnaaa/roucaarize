// Generated Array Test 12

function testArray12() {
    arr = []
    idx = 0
    while (idx < 28) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 28) { print("FATAL: array length mismatch") }
    if (arr[28-1] != (28-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray12()
}

main()
