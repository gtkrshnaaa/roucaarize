// Generated Array Test 16

function testArray16() {
    arr = []
    idx = 0
    while (idx < 37) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 37) { print("FATAL: array length mismatch") }
    if (arr[37-1] != (37-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray16()
}

main()
