// Generated Array Test 21

function testArray21() {
    arr = []
    idx = 0
    while (idx < 39) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 39) { print("FATAL: array length mismatch") }
    if (arr[39-1] != (39-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray21()
}

main()
