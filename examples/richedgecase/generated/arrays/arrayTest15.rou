// Generated Array Test 15

function testArray15() {
    arr = []
    idx = 0
    while (idx < 27) {
        arr.push(idx * 2)
        idx++
    }
    
    if (arr.length() != 27) { print("FATAL: array length mismatch") }
    if (arr[27-1] != (27-1)*2) { print("FATAL: array element mismatch") }
}

function main() {
    testArray15()
}

main()
